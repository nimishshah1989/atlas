#!/usr/bin/env bash
# forge-runner-status — thin launcher for scripts/forge_runner_status.py
# Executes the Python module so that scripts.forge_runner.* imports resolve.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec "${REPO_ROOT}/venv/bin/python" -c "
import sys, os
sys.path.insert(0, '${REPO_ROOT}')
from scripts.forge_runner_status import main
sys.exit(main())
" "$@"
