# ATLAS repository root .env.example
# The backend reads from backend/.env — see backend/.env.example for the
# authoritative list of variables. Duplicate here so tooling that scans the
# repo root (CI, dependabot, quality gate) can find it.

# --- Database (PostgreSQL RDS, JIP data engine) ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/data_engine
DATABASE_URL_SYNC=postgresql+psycopg2://USER:PASSWORD@HOST:5432/data_engine

# --- API server ---
ATLAS_API_HOST=0.0.0.0
ATLAS_API_PORT=8010

# --- CORS allowlist (comma-separated; no wildcards) ---
CORS_ORIGINS=https://atlas.jslwealth.in,http://localhost:3000,http://localhost:3001

# --- JIP Data Core internal API (read-only) ---
JIP_API_BASE_URL=http://172.31.10.182:8000

# --- Rate limiting (slowapi) ---
RATE_LIMIT_DEFAULT=60/minute
